# A1 Trainer - Environment Configuration
# Copy to .env and fill in your values

# Database (required -- no default)
# Dev:  A1_DATABASE_URL=sqlite+aiosqlite:///./a1_trainer.db
# Prod: A1_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/a1_trainer
A1_DATABASE_URL=sqlite+aiosqlite:///./a1_trainer.db

# Redis
A1_REDIS_URL=redis://localhost:6379/0

# Provider API Keys
A1_ANTHROPIC_API_KEY=sk-ant-your-key-here
A1_OPENAI_API_KEY=sk-your-key-here
A1_VERTEX_PROJECT_ID=
A1_VERTEX_LOCATION=us-central1

# Ollama
A1_OLLAMA_BASE_URL=http://localhost:11434

# Proxy auth (comma-separated API keys, empty = allow all)
A1_API_KEYS=

# Routing
A1_EXPLORATION_RATE=0.1
A1_DEFAULT_STRATEGY=best_quality

# Training
A1_TRAINING_BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
A1_TRAINING_LORA_RANK=16
A1_TRAINING_MIN_SAMPLES=500
A1_TRAINING_MIN_QUALITY=0.7
A1_TRAINING_OUTPUT_DIR=./training_outputs

# CORS
A1_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Debug
A1_DEBUG=false

# --- Open-source integrations ---

# LiteLLM (default: on — uses LiteLLM SDK for 100+ model support)
A1_USE_LITELLM=true

# Unsloth (default: on — 2-5x faster fine-tuning)
A1_USE_UNSLOTH=true

# GPTCache (semantic caching — reduces cost for repeated/similar queries)
A1_CACHE_ENABLED=false
A1_CACHE_SIMILARITY_THRESHOLD=0.8
A1_CACHE_TTL_SECONDS=3600
A1_CACHE_EMBEDDING=local
A1_CACHE_DB_PATH=./cache/gptcache.db

# OpenTelemetry (traces + metrics — set endpoint to enable)
# Start Jaeger: docker compose --profile observability up
A1_OTLP_ENDPOINT=
# A1_OTLP_ENDPOINT=http://localhost:4317

# Argilla (human feedback annotation)
# Start Argilla: docker compose --profile feedback up
A1_ARGILLA_API_URL=
# A1_ARGILLA_API_URL=http://localhost:6900
A1_ARGILLA_API_KEY=admin.apikey
A1_ARGILLA_WORKSPACE=default

# lm-evaluation-harness (standardized benchmarks)
A1_USE_HARNESS_EVAL=false
A1_HARNESS_DEFAULT_TASKS=["mmlu","hellaswag","truthfulqa_mc2"]
A1_HARNESS_NUM_FEWSHOT=5
A1_HARNESS_BATCH_SIZE=4
